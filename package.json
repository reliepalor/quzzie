{
  "name": "quizzie",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:quizzie": "node dist/quizzie/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
